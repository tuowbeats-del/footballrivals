# ============================================
# FootballRivals (footballrivals.be) - Environment Variables
# Kopieer dit bestand naar server/.env
# ============================================

# Database (Combell MySQL 8)
DATABASE_URL="mysql://DB_GEBRUIKER:DB_WACHTWOORD@DB_HOST:3306/DB_NAAM"

# JWT (gebruik een lange willekeurige string - min. 32 tekens)
JWT_SECRET=verander_dit_naar_iets_lang_willekeurig_min32tekens
JWT_EXPIRES_IN=7d

# Server
PORT=3001
NODE_ENV=production

# Client URL (je Combell domein, zonder trailing slash)
# Meerdere domeinen scheiden met komma
CLIENT_URL=https://footballrivals.be,https://www.footballrivals.be

# ============================================
# VOORBEELD voor lokaal development:
# DATABASE_URL="mysql://root:wachtwoord@localhost:3306/footballdraft"
# CLIENT_URL=http://localhost:5173
# NODE_ENV=development
# ============================================
